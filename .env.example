# DeepSeek API (text+SVG fallback model — server-side only)
DEEPSEEK_API_KEY=XX
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Doubao / 火山方舟 (Volcano Ark) — primary SVG model, server-side only.
# Preferred when set; if DOUBAO_API_KEY is unset the app falls back to DeepSeek
# automatically (see lib/ai/provider.ts). DOUBAO_MODEL is the Volcano endpoint
# id (e.g. ep-xxxxxxxxxxxx-xxxxx), NOT a model name like "doubao-pro".
DOUBAO_API_KEY=XX
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-your-endpoint-id

# Anthropic API (dormant — server-side only, lib/ai/svg-model.ts reference path)
ANTHROPIC_API_KEY=XX
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages

# Novus Analytics (reserved for future integration)
NEXT_PUBLIC_NOVUS_APP_ID=

# ----------------------------------------------------------------------------
# Volcano Engine — 大模型流式语音识别 (bigmodel_nostream endpoint)
# Server-side ONLY. NEVER use NEXT_PUBLIC_VOLC_* — exposing these to the
# browser violates AGENTS.md's server-side key rule and would leak credentials.
#
# Auth shape (one of the two):
#   New console (preferred): set VOLC_API_KEY
#   Old console            : set BOTH VOLC_APP_KEY and VOLC_ACCESS_KEY
#
# The /api/voice/capability route returns { available: true } iff one of the
# two shapes is fully configured; otherwise the client silently uses the
# browser Web Speech API (or typing) fallback.
#
# HTTPS / secure-context note: getUserMedia + AudioContext + audioWorklet
# require a secure context. Vercel previews/prod are HTTPS by default;
# `http://localhost:3001` is also secure-context-eligible.
# ----------------------------------------------------------------------------
VOLC_API_KEY=XX
# VOLC_APP_KEY=XX
# VOLC_ACCESS_KEY=XX
# Optional overrides (defaults shown):
# VOLC_RESOURCE_ID=volc.seedasr.sauc.duration
# VOLC_BASE_URL=wss://openspeech.bytedance.com
# VOLC_ENDPOINT_PATH=/api/v3/sauc/bigmodel_nostream
# VOLC_MODEL_NAME=bigmodel
